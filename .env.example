# =============================================================================
# Terra Forest — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file to git.

# ---- Database (Prisma) ----
# For local development with SQLite (quickstart):
# DATABASE_URL="file:./dev.db"
#
# For production / Vercel — use PostgreSQL (recommended):
#   - Vercel Postgres, Neon, Supabase, or Railway all work.
#   - Example: postgresql://user:password@host:5432/terra_forest?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/terra_forest?schema=public"

# ---- NextAuth (if used) ----
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL="http://localhost:3000"

# ---- JWT Auth (mobile app) ----
# JWT_SECRET="generate-with: openssl rand -base64 32"
# JWT_EXPIRES_IN="7d"

# ---- API Base URL (for Flutter mobile app) ----
# This is the URL the mobile app uses to reach this backend.
# For local Android emulator: http://10.0.2.2:3000
# For production: https://your-vercel-domain.vercel.app
API_BASE_URL="http://localhost:3000"

# ---- File uploads (optional) ----
# UPLOAD_DIR="./uploads"
# MAX_UPLOAD_MB="50"
