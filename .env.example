# =============================================================================
# Terra Forest — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file to git.

# ---- Database (Prisma) ----
# For local development with SQLite (quickstart):
# DATABASE_URL="file:./dev.db"
#
# For production / Vercel — use PostgreSQL (recommended):
#   - Vercel Postgres, Neon, Supabase, or Railway all work.
#   - Neon example (pooler endpoint, pgbouncer=true is required by Neon).
#
# IMPORTANT for Vercel: also add DATABASE_URL as a Vercel env var.
# The Neon serverless driver (used in src/lib/db.ts on Vercel) needs the
# pooler hostname (-pooler in the host segment) and pgbouncer=true.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true"

# Direct (non-pooled) URL — used by `prisma db push` and `prisma migrate`.
# For Neon: use the NON-pooler hostname here (without -pooler).
DIRECT_URL="postgresql://USER:PASSWORD@HOST.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Optional: force the Neon serverless adapter in local dev
# USE_NEON_ADAPTER="true"

# ---- NextAuth (if you switch to next-auth later) ----
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL="http://localhost:3000"

# ---- JWT Auth (used by the mobile app + /api/auth/* routes) ----
JWT_SECRET="generate-with: openssl rand -base64 32"
JWT_EXPIRES_IN="7d"

# ---- API Base URL (for Flutter mobile app) ----
# This is the URL the mobile app uses to reach this backend.
# For local Android emulator: http://10.0.2.2:3000
# For production: https://your-vercel-domain.vercel.app
API_BASE_URL="http://localhost:3000"

# ---- File uploads (optional) ----
# UPLOAD_DIR="./uploads"
# MAX_UPLOAD_MB="50"
